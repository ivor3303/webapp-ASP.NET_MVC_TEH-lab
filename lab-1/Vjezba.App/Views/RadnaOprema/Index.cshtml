@model IEnumerable<RadnaOprema>

@{
    ViewData["Title"] = "Radna oprema";

    string StatusClass(StatusOpreme status) => status switch
    {
        StatusOpreme.Ispravna => "status-chip status-ok",
        StatusOpreme.Neispravna => "status-chip status-danger",
        StatusOpreme.Otpisana => "status-chip status-muted",
        StatusOpreme.UServisu => "status-chip status-info",
        _ => "status-chip"
    };
}

<section>
    <h1>Radna oprema</h1>
    <p>Pregled sve evidentirane opreme.</p>
</section>

<section class="panel-grid">
@foreach (var item in Model)
{
    <article class="panel-card">
        <h2>@item.Naziv</h2>
        <p><strong>Inventarni broj:</strong> @item.InventarniBroj</p>
        <p><strong>Status:</strong> <span class="@StatusClass(item.Status)">@item.Status</span></p>
        <p><strong>Lokacija:</strong> @item.Lokacija.Naziv</p>
        <a asp-controller="RadnaOprema" asp-action="Details" asp-route-id="@item.Id">Detalji opreme</a>
    </article>
}
</section>
