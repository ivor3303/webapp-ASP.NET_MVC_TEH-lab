@model Izvjestaj

@{
    ViewData["Title"] = "Novi izvjestaj";
}

<section class="detail-panel">
    <h1>Novi izvjestaj</h1>

    <form asp-action="Create" method="post">
        <div>
            <label asp-for="Naziv"></label>
            <input asp-for="Naziv" class="form-control" />
            <span asp-validation-for="Naziv"></span>
        </div>

        <div>
            <label asp-for="DatumIzrade"></label>
            <input asp-for="DatumIzrade" type="date" class="form-control" />
            <span asp-validation-for="DatumIzrade"></span>
        </div>

        <div>
            <label asp-for="Opis"></label>
            <textarea asp-for="Opis" class="form-control"></textarea>
            <span asp-validation-for="Opis"></span>
        </div>

        <div>
            <label asp-for="RadnikId"></label>
            <input asp-for="RadnikId" class="form-control" />
            <span asp-validation-for="RadnikId"></span>
        </div>

        <button type="submit">Spremi</button>
    </form>
</section>